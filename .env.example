# ITUS Semantic Document Portal - Environment Variables
# Copy this file to .env for local development

# === Model Configuration ===
MODEL_NAME=distiluse-base-multilingual-cased-v1
COLLECTION_NAME=my_multilingual_docs

# === Qdrant Configuration ===
# Option 1: Qdrant Cloud (Recommended for production)
QDRANT_URL=https://your-cluster-id.us-east4-0.gcp.cloud.qdrant.io:6333

# Option 2: Self-hosted Qdrant
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# === Version Control ===
QDRANT_VERSION=1.15.1
QDRANT_CLIENT_VERSION=1.15.1

# === For Render Deployment ===
# Set these in Render Dashboard → Environment Variables:
# - QDRANT_URL: Your Qdrant Cloud cluster URL
# - MODEL_NAME: distiluse-base-multilingual-cased-v1
# - COLLECTION_NAME: my_multilingual_docs